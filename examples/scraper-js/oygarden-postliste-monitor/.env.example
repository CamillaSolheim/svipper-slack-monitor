# Anbefalt: Slack Bot API
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#varsler

# Fallback: Slack incoming webhook (valgfri)
SLACK_WEBHOOK_URL=

# Hvor state-filen lagres
STATE_FILE=./data/seen-cases.json

# Søketerm i postlisten
SEARCH_TERM=båtvrak

# Maks antall ganger vi klikker "Hent flere"
MAX_LOAD_MORE_CLICKS=40
